---
import BaseLayout from "../layouts/BaseLayout.astro";
import Cursor from "../components/Cursor.vue";
import ThemeToggle from "../components/ThemeToggle.vue";
import Hero from "../components/Hero.vue";
import Ticker from "../components/Ticker.vue";
import Manifesto from "../components/Manifesto.vue";
import WhyYou from "../components/WhyYou.vue";
import ProofOfWork from "../components/ProofOfWork.vue";
import DirectStatement from "../components/DirectStatement.vue";
import CTA from "../components/CTA.vue";
import Footer from "../components/Footer.vue";
---

<BaseLayout title="Ravikant" description="Application for Internship at Thine.">
    <Cursor client:load />
    <ThemeToggle client:load />

    <!-- ── HERO ── -->
    <Hero
        client:load
        stampLeft="Thine Growth Intern Application"
        headlineLeft="Hi Thine,<br>I am <em>Ravikant</em><br>from BITS."
        subLeft="M.Sc. Physics + B.E. EEE, BITS Hyderabad (2024-2029).<br>I ship experiments, build tools, and move metrics."
        stampRight="Growth · AI · Product"
        headlineRight="I want to<br><em>earn</em> this<br>role."
        subRight="Most applications explain. This one demonstrates. Here's how I think, what I've built, and why Thine specifically."
    />

    <!-- ── TICKER (between hero and about) ── -->
    <Ticker client:load :items={[]} />

    <!-- ── ABOUT ME ── -->
    <Manifesto client:visible label="§ About Me" :lines={[]} />

    <!-- ── WHY THINE ── -->
    <WhyYou client:visible label="§ Why Thine" :items={[]} />

    <!-- ── PAST WORK ── -->
    <ProofOfWork client:visible label="§ Past Work" :items={[]} />

    <!-- ── WHAT YOU GET ── -->
    <DirectStatement
        client:visible
        label="§ If You Hire Me"
        heading="What happens if you <em>hire me.</em>"
        :traits={[]}
        :closerLines={[]}
    />

    <!-- ── CTA ── -->
    <CTA
        client:visible
        headlineHtml="I don't interview well.<br> I ship well. <em>Let's find out.</em>"
        :links={[]}
        note=""
    />

    <!-- ── FOOTER ── -->
    <Footer
        client:visible
        left="Ravikant · Built for Thine · 2026"
        right="Resume and work summary"
        :actions={[]}
    />

    <!-- ── SCROLL REVEAL ── -->
    <script>
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) e.target.classList.add("revealed");
                });
            },
            { threshold: 0.1 },
        );
        document
            .querySelectorAll(".reveal")
            .forEach((el) => observer.observe(el));
    </script>
</BaseLayout>
